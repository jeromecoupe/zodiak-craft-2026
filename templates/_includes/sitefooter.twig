<footer class="c-sitefooter">
  <div class="l-container">
  
    <div class="c-sitefooter__contact">
      
      <div class="c-sitefooter__links">
        <ul class="c-contactlist">
          <li class="c-contactlist__item"><a class="c-contactlist__link" href="mailto:hello@zodiak.agency">{{ contact.contactEmail }}</a></li>
          <li class="c-contactlist__item"><a class="c-contactlist__link" href="tel:00322345678">{{ contact.contactPhone }}</a></li>
        </ul>
      </div>
      <div class="c-sitefooter__social">
        <nav aria-label="social media">
        {% for item in contact.contactSocialmedia.all() %}
        {% if loop.first %}<ul class="c-socialmedia">{% endif %}

            {% set svgIcon = item.socialIcon.one() %}
            <li class="c-socialmedia__item">
              <a 
                class="c-socialmedia__link" 
                href="{{ item.socialUrl.value }}" 
                aria-label="{{ item.socialLabel }}">
                  {% if svgIcon %}{{ svg(svgIcon) }}{% endif %}
              </a>
            </li>
        {% if loop.last %}</ul>{% endif %}
        {% endfor %}
        </nav>
      </div>
    </div>

    <div class="c-sitefooter__main">

      <div class="c-sitefooter__address">
        <address class="c-footeraddress">
          Zodiak Agency<br>
          Route de Blocry, 5<br>
          1348 Louvain-La-Neuve
        </address>
      </div>

      <div class="c-sitefooter__mainnav">
        {{ include("_includes/footer-mainnav.twig") }}
      </div>

      <div class="c-sitefooter__legalnav">
        {{ include("_includes/footer-legalnav.twig") }}
      </div>
      
    </div>

    <div class="c-sitefooter__end">
      <p class="c-copyright">&copy; 2026 - Zodiak Agency</p>
    </div>

  </div>
</footer>