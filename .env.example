# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# Security key (used for hashing)
CRAFT_SECURITY_KEY=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# mailpit (ddev mail server to send system emaiols: reset password, etc)
# not needed in production
MAILPIT_SMTP_HOSTNAME="127.0.0.1"
MAILPIT_SMTP_PORT="1025"

# Database connection data
CRAFT_DB_SERVER="db"
CRAFT_DB_DATABASE="db"
CRAFT_DB_USER="db"
CRAFT_DB_PORT="3306"
CRAFT_DB_PASSWORD="db"
CRAFT_DB_DRIVER="mysql"

# config options
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true

# variables used in cing file (config/general.php)
CP_TRIGGER=
PRIMARY_SITE_URL=
BASE_URL=
BASE_PATH=
